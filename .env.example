# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Databricks workspace host
DATABRICKS_HOST=https://<your-workspace>.azuredatabricks.net

# ADLS storage root for the retailflow catalog
# Find it with: databricks catalogs get <existing-catalog> --profile <profile>
# and copy the storage_root field.
CATALOG_STORAGE_ROOT=abfss://<container>@<storage-account>.dfs.core.windows.net/<workspace-id>
